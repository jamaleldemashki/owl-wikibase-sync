# Copy this file to .env and fill in real values. Never commit .env.
#
# WIKIBASE_URL: the base URL of the Wikibase instance (concept/entity base).
#   For wikibase.cloud instances this is typically the site root, e.g.
#   https://example.wikibase.cloud
WIKIBASE_URL=https://example.wikibase.cloud

# WIKIBASE_API_URL: the MediaWiki action API endpoint.
WIKIBASE_API_URL=https://example.wikibase.cloud/w/api.php

# WIKIBASE_SPARQL_URL: the SPARQL query service endpoint, used for identity
# lookups (finding an existing item by its ontology_iri) and reconciliation.
# Leave blank if the instance has no SPARQL endpoint -- the pipeline will
# fall back to cache-only duplicate detection and log a warning.
WIKIBASE_SPARQL_URL=https://example.wikibase.cloud/query/sparql

# Bot credentials (Special:BotPasswords on the Wikibase instance). Required
# only for live writes; dry-run mode works without them.
WIKIBASE_BOT_USERNAME=replace_me
WIKIBASE_BOT_PASSWORD=replace_me
